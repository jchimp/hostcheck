#!/usr/bin/env bash
###############################################################################
# hostcheck
#
# Master dispatcher for the hostcheck suite.
# Installed at: /usr/local/bin/hostcheck
#
# Usage:
#   hostcheck <module> [args...]          Run a module
#   hostcheck enable <module|all>         Create cron job for module(s)
#   hostcheck disable <module|all>        Remove cron job for module(s)
#   hostcheck cron                        Show all installed cron jobs
#   hostcheck log [module]                Tail module log(s)
#   hostcheck status                      Show enabled modules and notification config
#   hostcheck help                        Show this help
###############################################################################

set -Euo pipefail

export PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:${PATH}"

SCRIPT_DIR="/usr/local/bin"
CONF_FILE="/etc/hostcheck/hostcheck.conf"
LOG_DIR="/var/log/hostcheck"
CRON_DIR="/etc/cron.d"
CRON_PATTERN="${CRON_DIR}/hostcheck-*"

MODULES=(health sec mail oauth-token)

declare -A MODULE_CRON_SCHEDULE=(
  [health]="*/5 * * * *"
  [sec]="*/15 * * * *"
  [mail]="*/5 * * * *"
  [oauth-token]="*/30 * * * *"
)

# ── Helpers ───────────────────────────────────────────────────────────────────
die() { echo "ERROR: $*" >&2; exit 1; }

require_root() {
  [[ "$EUID" -eq 0 ]] || die "This command requires root. Run: sudo hostcheck $*"
}

validate_module() {
  local module="$1"
  for m in "${MODULES[@]}"; do
    [[ "$m" == "$module" ]] && return 0
  done
  die "Unknown module: ${module}. Valid modules: ${MODULES[*]}"
}

usage() {
  cat <<EOF
Usage: hostcheck <command> [options]

Commands:
  health [args]              Run the system health module
  sec [args]                 Run the security module
  mail [args]                Run the mail relay module
  oauth-token [args]         Run the OAuth token module
  enable <module|all>        Enable module(s) by installing cron job(s)
  disable <module|all>       Disable module(s) by removing cron job(s)
  cron                       List installed hostcheck cron jobs
  log [module]               Tail log(s) — omit module to tail all
  status                     Show enabled modules and notification config
  testalert                  Send a test notification via all enabled channels
  help                       Show this help

Module args (passed through to the underlying script):
  --dry-run           Run without sending alerts or updating state
  --reset-baseline    Reset stored baselines (health, sec, mail)
  --check-refresh     Force OAuth token refresh test (oauth-token only)
  --config <path>     Override config file path

Examples:
  hostcheck health --dry-run
  hostcheck enable health
  hostcheck enable all
  hostcheck disable sec
  hostcheck log health
  hostcheck status
EOF
}

# ── Module runner ─────────────────────────────────────────────────────────────
run_module() {
  local module="$1"; shift
  local script="${SCRIPT_DIR}/hostcheck-${module}.sh"
  if [[ ! -x "$script" ]]; then
    echo "ERROR: Module script not found or not executable: ${script}" >&2
    echo "       Run install.sh to install hostcheck." >&2
    exit 1
  fi
  exec "$script" "$@"
}

# ── Enable / Disable ──────────────────────────────────────────────────────────
_enable_one() {
  local module="$1"
  local script="${SCRIPT_DIR}/hostcheck-${module}.sh"
  local cron_file="${CRON_DIR}/hostcheck-${module}"
  local schedule="${MODULE_CRON_SCHEDULE[$module]}"
  local log_file="${LOG_DIR}/hostcheck-${module}.log"

  if [[ ! -x "$script" ]]; then
    echo "  ERROR: script not found or not executable: ${script}" >&2
    echo "         Run install.sh first." >&2
    return 1
  fi

  cat > "$cron_file" <<EOF
# hostcheck-${module} — managed by: hostcheck enable/disable
${schedule} root ${script} >> /dev/null 2>&1
EOF
  chmod 644 "$cron_file"
  touch "$log_file"
  echo "  Enabled:  ${module}  (${schedule})"
}

_disable_one() {
  local module="$1"
  local cron_file="${CRON_DIR}/hostcheck-${module}"

  if [[ -f "$cron_file" ]]; then
    rm -f "$cron_file"
    echo "  Disabled: ${module}"
  else
    echo "  Already disabled: ${module}"
  fi
}

cmd_enable() {
  local target="$1"
  require_root "enable ${target}"

  if [[ "$target" == "all" ]]; then
    for m in "${MODULES[@]}"; do
      _enable_one "$m"
    done
  else
    validate_module "$target"
    _enable_one "$target"
  fi
}

cmd_disable() {
  local target="$1"
  require_root "disable ${target}"

  if [[ "$target" == "all" ]]; then
    for m in "${MODULES[@]}"; do
      _disable_one "$m"
    done
  else
    validate_module "$target"
    _disable_one "$target"
  fi
}

# ── Cron / Log / Status ───────────────────────────────────────────────────────
cmd_cron() {
  local found=0
  for f in $CRON_PATTERN; do
    [[ -f "$f" ]] || continue
    echo "── $f ──"
    cat "$f"
    echo
    found=1
  done
  if [[ "$found" -eq 0 ]]; then
    echo "No hostcheck cron jobs found (expected: ${CRON_PATTERN})"
  fi
}

cmd_log() {
  local module="${1:-}"
  if [[ -n "$module" ]]; then
    local logfile="${LOG_DIR}/hostcheck-${module}.log"
    if [[ ! -f "$logfile" ]]; then
      echo "Log file not found: ${logfile}" >&2
      exit 1
    fi
    exec tail -f "$logfile"
  else
    local logs=()
    for m in "${MODULES[@]}"; do
      local lf="${LOG_DIR}/hostcheck-${m}.log"
      [[ -f "$lf" ]] && logs+=("$lf")
    done
    if [[ "${#logs[@]}" -eq 0 ]]; then
      echo "No log files found in ${LOG_DIR}" >&2
      exit 1
    fi
    exec tail -f "${logs[@]}"
  fi
}

cmd_status() {
  echo "══ hostcheck status ══════════════════════════════════"
  echo ""

  if [[ ! -f "$CONF_FILE" ]]; then
    echo "  Config not found: ${CONF_FILE}"
    echo "  Run install.sh to set up hostcheck."
    exit 0
  fi

  # shellcheck disable=SC1090
  source "$CONF_FILE"

  echo "  Config: ${CONF_FILE}"
  echo ""
  echo "  Modules:"
  for m in "${MODULES[@]}"; do
    local script="${SCRIPT_DIR}/hostcheck-${m}.sh"
    local cron="${CRON_DIR}/hostcheck-${m}"
    local enabled="false"
    local script_status="[no script]"
    [[ -f "$cron" ]]   && enabled="true"
    [[ -x "$script" ]] && script_status="installed"
    printf "    %-15s  enabled=%-5s  script=%-12s\n" "$m" "$enabled" "$script_status"
  done

  echo ""
  echo "  Notifications:"
  printf "    Telegram: %s\n" "${TELEGRAM_ENABLED:-false}"
  if [[ "${TELEGRAM_ENABLED:-false}" == "true" ]]; then
    local tok="${TELEGRAM_BOT_TOKEN:-}"
    printf "    Bot token: %s\n" "${tok:0:12}..."
    printf "    Chat ID:   %s\n" "${TELEGRAM_CHAT_ID:-<not set>}"
  fi
  printf "    Email:    %s\n" "${EMAIL_ENABLED:-false}"
  if [[ "${EMAIL_ENABLED:-false}" == "true" ]]; then
    printf "    To:       %s\n" "${EMAIL_TO:-<not set>}"
    printf "    From:     %s\n" "${EMAIL_FROM:-<not set>}"
  fi
  printf "    Syslog:   %s\n" "${SYSLOG_ENABLED:-true}"
  printf "    Cooldown: %ss\n" "${ALERT_COOLDOWN_SEC:-3600}"
  echo ""
}

# ── Test Alert ───────────────────────────────────────────────────────────────
cmd_testalert() {
  if [[ ! -f "$CONF_FILE" ]]; then
    die "Config not found: ${CONF_FILE}. Run install.sh to set up hostcheck."
  fi

  # shellcheck disable=SC1090
  source "$CONF_FILE"

  local hostname_short
  hostname_short="$(hostname -s 2>/dev/null || hostname)"
  local timestamp
  timestamp="$(date '+%Y-%m-%d %H:%M:%S')"
  local sent=0

  echo "Sending test notifications..."

  if [[ "${TELEGRAM_ENABLED:-false}" == "true" ]]; then
    if [[ -z "${TELEGRAM_BOT_TOKEN:-}" || -z "${TELEGRAM_CHAT_ID:-}" ]]; then
      echo "  Telegram: SKIP (enabled but token/chat_id not set)"
    else
      local tg_msg
      tg_msg="$(printf '<b>hostcheck test alert</b>\nThis is a test notification from hostcheck on <code>%s</code>.\n<i>%s</i>' "$hostname_short" "$timestamp")"
      if curl -s --max-time 10 \
          -X POST "https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/sendMessage" \
          -d chat_id="${TELEGRAM_CHAT_ID}" \
          -d parse_mode="HTML" \
          -d text="${tg_msg}" \
          >/dev/null 2>&1; then
        echo "  Telegram: OK"
        sent=$((sent + 1))
      else
        echo "  Telegram: FAILED (curl error)"
      fi
    fi
  else
    echo "  Telegram: SKIP (disabled)"
  fi

  if [[ "${EMAIL_ENABLED:-false}" == "true" ]]; then
    if [[ -z "${EMAIL_TO:-}" ]]; then
      echo "  Email:    SKIP (enabled but EMAIL_TO not set)"
    else
      local subject="[hostcheck] test alert from ${hostname_short}"
      local body
      body="$(printf 'This is a test notification from hostcheck.\n\nHost: %s\nTime: %s\n' "$hostname_short" "$timestamp")"
      local mail_ok=0
      if command -v msmtp &>/dev/null; then
        printf 'From: %s\nTo: %s\nSubject: %s\n\n%s\n' \
          "${EMAIL_FROM:-hostcheck@${hostname_short}}" "$EMAIL_TO" "$subject" "$body" \
          | msmtp "$EMAIL_TO" 2>/dev/null && mail_ok=1
      elif command -v sendmail &>/dev/null; then
        printf 'From: %s\nTo: %s\nSubject: %s\n\n%s\n' \
          "${EMAIL_FROM:-hostcheck@${hostname_short}}" "$EMAIL_TO" "$subject" "$body" \
          | sendmail -t 2>/dev/null && mail_ok=1
      elif command -v mail &>/dev/null; then
        echo "$body" | mail -s "$subject" "$EMAIL_TO" 2>/dev/null && mail_ok=1
      else
        echo "  Email:    SKIP (no mail binary found: msmtp, sendmail, mail)"
        mail_ok=-1
      fi
      if [[ "$mail_ok" -eq 1 ]]; then
        echo "  Email:    OK  (to: ${EMAIL_TO})"
        sent=$((sent + 1))
      elif [[ "$mail_ok" -eq 0 ]]; then
        echo "  Email:    FAILED (send error)"
      fi
    fi
  else
    echo "  Email:    SKIP (disabled)"
  fi

  if [[ "${SYSLOG_ENABLED:-true}" == "true" ]]; then
    if command -v logger &>/dev/null; then
      logger -t hostcheck "test alert from ${hostname_short} at ${timestamp}"
      echo "  Syslog:   OK"
      sent=$((sent + 1))
    else
      echo "  Syslog:   SKIP (logger not found)"
    fi
  else
    echo "  Syslog:   SKIP (disabled)"
  fi

  echo ""
  echo "Done. ${sent} channel(s) notified."
}

# ── Dispatch ──────────────────────────────────────────────────────────────────
case "${1:-}" in
  health|sec|mail|oauth-token)
    module="$1"; shift
    run_module "$module" "$@"
    ;;
  enable)
    [[ -n "${2:-}" ]] || { echo "Usage: hostcheck enable <module|all>" >&2; exit 1; }
    cmd_enable "$2"
    ;;
  disable)
    [[ -n "${2:-}" ]] || { echo "Usage: hostcheck disable <module|all>" >&2; exit 1; }
    cmd_disable "$2"
    ;;
  cron)
    cmd_cron
    ;;
  log)
    shift
    cmd_log "${1:-}"
    ;;
  status)
    cmd_status
    ;;
  testalert)
    cmd_testalert
    ;;
  help|-h|--help)
    usage
    ;;
  "")
    usage
    exit 1
    ;;
  *)
    echo "Unknown command: $1" >&2
    usage >&2
    exit 1
    ;;
esac
